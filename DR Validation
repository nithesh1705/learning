def print_final_summary() -> None:
    print_header("FINAL DR VERIFICATION SUMMARY")
    categories = sorted(set(result.category for result in results))
    total_pass = sum(1 for result in results if result.status == PASS)
    total_fail = sum(1 for result in results if result.status == FAIL)
    total_warn = sum(1 for result in results if result.status == WARN)

    print(f"{'CATEGORY':<22} {'ITEM':<42} {'STATUS':<8} DETAILS", flush=True)
    print("-" * 120, flush=True)
    for result in results:
        item = result.item[:39] + "..." if len(result.item) > 42 else result.item
        details = result.details.replace("\n", " ")
        print(f"{result.category:<22} {item:<42} {result.status:<8} {details}", flush=True)

    print("\nCategory Status:", flush=True)
    for category in categories:
        category_results = [result for result in results if result.category == category]
        passed = sum(1 for result in category_results if result.status == PASS)
        failed = sum(1 for result in category_results if result.status == FAIL)
        warned = sum(1 for result in category_results if result.status == WARN)
        overall = FAIL if failed else WARN if warned else PASS
        print(f"  {category:<22} {overall:<8} PASS={passed} FAIL={failed} WARN={warned}", flush=True)

    print("\nOverall Status:", flush=True)
    overall_status = FAIL if total_fail else WARN if total_warn else PASS
    print(f"  {overall_status} | PASS={total_pass} FAIL={total_fail} WARN={total_warn} TOTAL={len(results)}", flush=True)

    with open(RESULT_JSON_FILE, "w", encoding="utf-8") as file:
        json.dump([asdict(result) for result in results], file, indent=2)
    print_step(f"Detailed JSON result saved to: {Path(RESULT_JSON_FILE).resolve()}")


def main() -> int:
    start = time.time()
    print_header("DR VERIFICATION STARTED")
    print_step(f"Started at: {time.strftime('%Y-%m-%d %H:%M:%S')}")

    print_system_info()
    check_telnet()
    check_applications()
    check_folder_access()
    check_proxy()
    check_ssl_certifications()
    check_python_packages()
    check_urls()
    print_final_summary()

    elapsed = time.time() - start
    print_step(f"Completed in {elapsed:.2f} seconds.")
    return 1 if any(result.status == FAIL for result in results) else 0


if __name__ == "__main__":
    raise SystemExit(main())
