PASS = "PASS"
FAIL = "FAIL"
WARN = "WARN"


@dataclass
class Result:
    category: str
    item: str
    status: str
    details: str


results: list[Result] = []


def print_header(title: str) -> None:
    line = "=" * 78
    print(f"\n{line}\n{title}\n{line}", flush=True)


def print_step(message: str) -> None:
    print(f"[{time.strftime('%H:%M:%S')}] {message}", flush=True)


def add_result(category: str, item: str, status: str, details: str) -> None:
    results.append(Result(category, item, status, details))
    print(f"    -> {status}: {details}", flush=True)


def run_command(command: list[str], timeout: int = COMMAND_TIMEOUT_SECONDS) -> tuple[int, str]:
    print_step("CMD: " + " ".join(command))
    try:
        completed = subprocess.run(
            command,
            capture_output=True,
            text=True,
            timeout=timeout,
            shell=False,
        )
        output = (completed.stdout or "") + (completed.stderr or "")
        if output.strip():
            print(output.strip(), flush=True)
        return completed.returncode, output.strip()
    except subprocess.TimeoutExpired as exc:
        output = (exc.stdout or "") + (exc.stderr or "")
        if isinstance(output, bytes):
            output = output.decode(errors="replace")
        return 124, f"Timed out after {timeout} seconds. {output}".strip()
    except FileNotFoundError as exc:
        return 127, str(exc)
    except Exception as exc:
        return 1, str(exc)


def normalize_host_from_url(url: str) -> str:
    parsed = urllib.parse.urlparse(url if "://" in url else f"https://{url}")
    return parsed.hostname or url


def check_telnet() -> None:
    print_header("TELNET / PORT CONNECTIVITY CHECKS")
    telnet_path = shutil.which("telnet")
    if not telnet_path:
        print_step("Windows telnet command not found. Socket fallback will still check connectivity.")

    for target in TELNET_TARGETS:
        name = target.get("name") or target.get("ip")
        ip = str(target["ip"])
        port = int(target["port"])
        item = f"{name} ({ip}:{port})"

        if telnet_path:
            code, output = run_command(["cmd", "/c", "telnet", ip, str(port)], timeout=COMMAND_TIMEOUT_SECONDS)
            if code == 0:
                add_result("Telnet", item, PASS, "telnet command completed successfully.")
                continue
            if code == 124:
                print_step("Telnet command timed out. Trying socket connectivity check.")
            else:
                print_step(f"Telnet command returned code {code}. Trying socket connectivity check.")
                if output:
                    print_step(output)

        try:
            print_step(f"SOCKET: testing {ip}:{port}")
            with socket.create_connection((ip, port), timeout=COMMAND_TIMEOUT_SECONDS):
                add_result("Telnet", item, PASS, "TCP port is reachable by socket check.")
        except Exception as exc:
            add_result("Telnet", item, FAIL, f"TCP port is not reachable. {exc}")


def registry_app_path(executable: str) -> str:
    subkey = rf"SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\{executable}"
    roots = [
        (winreg.HKEY_LOCAL_MACHINE, winreg.KEY_WOW64_64KEY),
        (winreg.HKEY_LOCAL_MACHINE, winreg.KEY_WOW64_32KEY),
        (winreg.HKEY_CURRENT_USER, 0),
    ]
    for root, flags in roots:
        try:
            with winreg.OpenKey(root, subkey, 0, winreg.KEY_READ | flags) as key:
                value, _ = winreg.QueryValueEx(key, None)
                if value and Path(value).exists():
                    return value
        except OSError:
            continue
    return ""


def check_applications() -> None:
    print_header("APPLICATION INSTALLATION CHECKS")
    for app_key, config in APPLICATIONS.items():
        display_name = config["display_name"]
        print_step(f"Checking application: {display_name}")
        found_paths: list[str] = []

        for exe in config.get("executables", []):
            found = shutil.which(exe)
            if found:
                found_paths.append(found)
            reg_found = registry_app_path(exe)
            if reg_found:
                found_paths.append(reg_found)

        for common_path in config.get("common_paths", []):
            if Path(common_path).exists():
                found_paths.append(common_path)

        unique_paths = sorted(set(found_paths))
        if unique_paths:
            add_result("Applications", display_name, PASS, "Found: " + "; ".join(unique_paths))
        else:
            add_result("Applications", display_name, FAIL, f"{app_key} executable not found.")


def check_folder_access() -> None:
    print_header("FOLDER AND SHAREDRIVE ACCESS CHECKS")
    for path_text in FOLDER_ACCESS_PATHS:
        path = Path(path_text)
        print_step(f"Checking folder/share path: {path_text}")
        try:
            if not path.exists():
                add_result("Folder Access", path_text, FAIL, "Path does not exist or is not reachable.")
                continue
            if not path.is_dir():
                add_result("Folder Access", path_text, FAIL, "Path exists but is not a folder.")
                continue
            entries = list(path.iterdir())
            sample_count = min(len(entries), 5)
            add_result("Folder Access", path_text, PASS, f"Accessible. Items visible: {len(entries)}. Sample checked: {sample_count}.")
        except PermissionError as exc:
            add_result("Folder Access", path_text, FAIL, f"Permission denied. {exc}")
        except Exception as exc:
            add_result("Folder Access", path_text, FAIL, str(exc))


def get_windows_proxy_settings() -> dict[str, Any]:
    settings: dict[str, Any] = {}
    key_path = r"Software\Microsoft\Windows\CurrentVersion\Internet Settings"
    try:
        with winreg.OpenKey(winreg.HKEY_CURRENT_USER, key_path) as key:
            for value_name in ["ProxyEnable", "ProxyServer", "ProxyOverride", "AutoConfigURL"]:
                try:
                    value, _ = winreg.QueryValueEx(key, value_name)
                    settings[value_name] = value
                except OSError:
                    settings[value_name] = None
    except OSError as exc:
        settings["error"] = str(exc)
    return settings


def check_proxy() -> None:
    print_header("PROXY SETTINGS CHECK")
    settings = get_windows_proxy_settings()
    print_step("Windows proxy settings:")
    print(json.dumps(settings, indent=2), flush=True)

    proxy_enabled = bool(settings.get("ProxyEnable"))
    expected_enabled = PROXY_SETTINGS.get("expected_proxy_enabled")
    expected_server = str(PROXY_SETTINGS.get("expected_proxy_server") or "").strip()
    actual_server = str(settings.get("ProxyServer") or "").strip()

    if expected_enabled is None:
        add_result("Proxy", "Windows Proxy Enabled", WARN, f"Report only. ProxyEnable={proxy_enabled}.")
    elif proxy_enabled == expected_enabled:
        add_result("Proxy", "Windows Proxy Enabled", PASS, f"ProxyEnable={proxy_enabled}.")
    else:
        add_result("Proxy", "Windows Proxy Enabled", FAIL, f"Expected {expected_enabled}, found {proxy_enabled}.")

    if expected_server:
        if expected_server.lower() == actual_server.lower():
            add_result("Proxy", "Windows Proxy Server", PASS, actual_server)
        else:
            add_result("Proxy", "Windows Proxy Server", FAIL, f"Expected '{expected_server}', found '{actual_server}'.")
    else:
        add_result("Proxy", "Windows Proxy Server", WARN, f"Report only. ProxyServer='{actual_server}'.")

    test_url = PROXY_SETTINGS.get("test_url")
    if test_url:
        check_single_url(str(test_url), category="Proxy URL Test")


def check_ssl_certifications() -> None:
    print_header("SSL CERTIFICATION CHECKS")
    for cert in SSL_CERTIFICATIONS:
        cert_type = str(cert.get("type", "")).lower()
        name = str(cert.get("name") or cert.get("host") or cert.get("path"))
        print_step(f"Checking SSL certification item: {name}")

        if cert_type == "file":
            path_text = str(cert.get("path", ""))
            path = Path(path_text)
            if path.exists() and path.is_file():
                add_result("SSL", name, PASS, f"Certificate file found: {path_text}")
            else:
                add_result("SSL", name, FAIL, f"Certificate file not found: {path_text}")
            continue

        if cert_type == "host":
            host = str(cert["host"])
            port = int(cert.get("port", 443))
            try:
                context = ssl.create_default_context()
                with socket.create_connection((host, port), timeout=COMMAND_TIMEOUT_SECONDS) as sock:
                    with context.wrap_socket(sock, server_hostname=host) as secure_sock:
                        certificate = secure_sock.getpeercert()
                not_after = certificate.get("notAfter", "unknown")
                add_result("SSL", name, PASS, f"SSL handshake successful. Certificate expiry: {not_after}")
            except Exception as exc:
                add_result("SSL", name, FAIL, f"SSL check failed. {exc}")
            continue

        if cert_type == "store_subject":
            subject = str(cert.get("subject", "")).strip()
            code, output = run_command(["cmd", "/c", "certutil", "-store", "Root"], timeout=COMMAND_TIMEOUT_SECONDS)
            if code == 0 and subject and subject.lower() in output.lower():
                add_result("SSL", name, PASS, f"Certificate subject found in Root store: {subject}")
            elif code == 0:
                add_result("SSL", name, FAIL, f"Certificate subject not found in Root store: {subject}")
            else:
                add_result("SSL", name, FAIL, f"certutil failed. {output[-500:]}")
            continue

        add_result("SSL", name, FAIL, f"Unknown SSL check type: {cert_type}")


def installed_python_packages() -> set[str]:
    packages = set()
    for dist in importlib.metadata.distributions():
        name = dist.metadata.get("Name")
        if name:
            packages.add(name.lower())
    return packages


def pip_install(package: str) -> tuple[bool, str]:
    command = [sys.executable, "-m", "pip", "install", package]
    code, output = run_command(command, timeout=300)
    return code == 0, output


def check_python_packages() -> None:
    print_header("PYTHON PACKAGE CHECKS")
    installed = installed_python_packages()
    for package in PYTHON_PACKAGES:
        package_name = package.strip()
        if not package_name:
            continue
        print_step(f"Checking Python package: {package_name}")
        if package_name.lower() in installed:
            version = importlib.metadata.version(package_name)
            add_result("Python Packages", package_name, PASS, f"Installed. Version: {version}")
            continue

        if not INSTALL_MISSING_PACKAGES:
            add_result("Python Packages", package_name, FAIL, "Not installed. Auto install disabled.")
            continue

        print_step(f"Package missing. Installing with pip: {package_name}")
        success, output = pip_install(package_name)
        if success:
            try:
                version = importlib.metadata.version(package_name)
            except importlib.metadata.PackageNotFoundError:
                version = "installed, version not detected"
            add_result("Python Packages", package_name, PASS, f"Installed successfully. Version: {version}")
        else:
            add_result("Python Packages", package_name, FAIL, f"Install failed. {output[-500:]}")


def check_single_url(url: str, category: str = "URLs") -> None:
    full_url = url if "://" in url else f"https://{url}"
    host = normalize_host_from_url(full_url)
    print_step(f"Checking URL: {full_url}")
    run_command(["cmd", "/c", "nslookup", host], timeout=COMMAND_TIMEOUT_SECONDS)

    request = urllib.request.Request(
        full_url,
        headers={"User-Agent": "DR-Verification-Python/1.0"},
        method="GET",
    )
    try:
        with urllib.request.urlopen(request, timeout=URL_TIMEOUT_SECONDS) as response:
            status_code = response.getcode()
            add_result(category, full_url, PASS, f"Reachable. HTTP status: {status_code}")
    except urllib.error.HTTPError as exc:
        if 200 <= exc.code < 500:
            add_result(category, full_url, WARN, f"Server responded with HTTP status: {exc.code}")
        else:
            add_result(category, full_url, FAIL, f"HTTP error: {exc.code}")
    except Exception as exc:
        add_result(category, full_url, FAIL, f"URL not reachable. {exc}")


def check_urls() -> None:
    print_header("URL ACCESS CHECKS")
    for url in URLS:
        check_single_url(url)


